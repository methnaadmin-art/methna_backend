# App
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1

# JWT
JWT_SECRET=change-me-in-production
JWT_EXPIRATION=15m
JWT_REFRESH_SECRET=change-me-in-production
JWT_REFRESH_EXPIRATION=7d

# Database (PostgreSQL)
DB_HOST=your-postgres-host
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=your-postgres-password
DB_NAME=postgres
DB_SSL=true

# Redis (ioredis TCP - use rediss:// for TLS)
REDIS_URL=rediss://your-upstash-or-redis-endpoint
REDIS_TOKEN=your-redis-token

# Cloudinary
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# Throttle
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# CORS
CORS_ORIGIN=*

# Mail (SMTP - Gmail App Password or Mailtrap)
MAIL_HOST="smtp.gmail.com"
MAIL_PORT="587"
MAIL_USER="your-smtp-user"
MAIL_PASS="your-smtp-password"
MAIL_FROM="no-reply@your-domain.com"

# Stripe Payments
STRIPE_SECRET_KEY=sk_test_YOUR_STRIPE_SECRET_KEY
STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_STRIPE_PUBLISHABLE_KEY
STRIPE_WEBHOOK_SECRET=whsec_YOUR_STRIPE_WEBHOOK_SECRET
STRIPE_SUCCESS_URL=methna://payment-success
STRIPE_CANCEL_URL=methna://payment-cancel
STRIPE_MANAGEMENT_URL=https://billing.stripe.com/p/login
STRIPE_PRICE_PREMIUM=price_YOUR_PREMIUM_PLAN_ID
STRIPE_PRICE_GOLD=price_YOUR_GOLD_PLAN_ID

# Google OAuth
GOOGLE_WEB_CLIENT_ID=YOUR_GOOGLE_WEB_CLIENT_ID
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID

# Google Play Billing
GOOGLE_PLAY_ALLOW_UNVERIFIED_TOKENS=false
GOOGLE_PLAY_CLIENT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_PLAY_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"
GOOGLE_PLAY_PACKAGE_NAME=com.your.app.package
GOOGLE_PLAY_LICENSING_PUBLIC_KEY=YOUR_BASE64_ENCODED_RSA_PUBLIC_KEY
GOOGLE_PLAY_SUBSCRIPTION_MANAGEMENT_URL=https://play.google.com/store/account/subscriptions
GOOGLE_PLAY_UCB_ELIGIBLE_COUNTRIES=GB

# Firebase (for push notifications)
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_CLIENT_EMAIL=your_client_email
FIREBASE_PRIVATE_KEY=your_private_key
FCM_SERVER_KEY=

# Google Sign-In
GOOGLE_WEB_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com

# Trust & Safety
TRUST_SCORE_THRESHOLD=20
SHADOW_BAN_AUTO_THRESHOLD=20
MAX_DAILY_SWIPES_FREE=200
SELFIE_VERIFICATION_REQUIRED=false
BACKGROUND_CHECK_API_KEY=

# Security
MAX_DEVICES_PER_USER=5
IP_RATE_LIMIT_PER_HOUR=100
LOGIN_SUSPICIOUS_IP_THRESHOLD=5
SESSION_MAX_AGE_DAYS=30
CHAT_ENCRYPTION_KEY=

# Monetization (PDF spec)
FREE_DAILY_LIKES=10
FREE_DAILY_SUPER_LIKES=0
FREE_MONTHLY_REWINDS=2
PREMIUM_DAILY_SUPER_LIKES=5
PREMIUM_DAILY_COMPLIMENT_CREDITS=1
PREMIUM_WEEKLY_BOOSTS=4
BOOST_DURATION_MINUTES=30
PREMIUM_PRICE_MONTHLY=9.99
GOLD_PRICE_MONTHLY=19.99

# Stripe Checkout + Webhook
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_SUCCESS_URL=methna://payment-success
STRIPE_CANCEL_URL=methna://payment-cancel

# Optional fallback Price IDs (used when plan.stripePriceId is missing in DB)
# STRIPE_PRICE_PREMIUM=price_xxx
# STRIPE_PRICE_GOLD=price_xxx

