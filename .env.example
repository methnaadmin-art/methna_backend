# App
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1

# JWT
JWT_SECRET=your_jwt_secret
JWT_EXPIRATION=15m
JWT_REFRESH_SECRET=your_refresh_secret
JWT_REFRESH_EXPIRATION=7d

# Database (PostgreSQL)
DB_HOST=your_db_host
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=your_db_password
DB_NAME=postgres
DB_SSL=true

# Redis
REDIS_URL=your_redis_url
REDIS_TOKEN=your_redis_token

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Throttle
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# CORS
CORS_ORIGIN=*

# Mail (SMTP)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your_email@gmail.com
MAIL_PASS=your_app_password
MAIL_FROM=noreply@wafaa.app

# OTP
OTP_EXPIRY_SECONDS=30
OTP_COOLDOWN_SECONDS=60
OTP_MAX_ATTEMPTS=5

# Firebase (for push notifications)
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_CLIENT_EMAIL=your_client_email
FIREBASE_PRIVATE_KEY=your_private_key

# Trust & Safety
TRUST_SCORE_THRESHOLD=20
SHADOW_BAN_AUTO_THRESHOLD=20
MAX_DAILY_SWIPES_FREE=200
SELFIE_VERIFICATION_REQUIRED=false

# Security
MAX_DEVICES_PER_USER=5
IP_RATE_LIMIT_PER_HOUR=100
LOGIN_SUSPICIOUS_IP_THRESHOLD=5
SESSION_MAX_AGE_DAYS=30

# Monetization
FREE_DAILY_LIKES=25
FREE_DAILY_SUPER_LIKES=1
PREMIUM_DAILY_SUPER_LIKES=5
BOOST_DURATION_MINUTES=30
PREMIUM_PRICE_MONTHLY=9.99
GOLD_PRICE_MONTHLY=19.99
