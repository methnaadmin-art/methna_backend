' ============================================================
' ENTITIES
' ============================================================

package "Entities (PostgreSQL)" <<Database>> #E8F5E9 {

    class User {
        +id : UUID <<PK>>
        +username : varchar <<unique, nullable>>
        +email : varchar <<unique>>
        +password : varchar
        +firstName : varchar
        +lastName : varchar
        +phone : varchar?
        +role : UserRole
        +status : UserStatus
        +refreshToken : varchar?
        +emailVerified : boolean
        +otpCode : varchar?
        +otpExpiresAt : timestamp?
        +otpAttempts : int
        +selfieVerified : boolean
        +selfieUrl : varchar?
        +fcmToken : varchar?
        +notificationsEnabled : boolean
        +matchNotifications : boolean
        +messageNotifications : boolean
        +likeNotifications : boolean
        +locationEnabled : boolean
        +boostedUntil : timestamp?
        +isShadowBanned : boolean
        +trustScore : int [0-100]
        +flagCount : int
        +lastKnownIp : varchar?
        +deviceCount : int
        +lastLoginAt : timestamp?
        +createdAt : timestamp
        +updatedAt : timestamp
        +deletedAt : timestamp? <<soft delete>>
    }

    class Profile {
        +id : UUID <<PK>>
        +userId : UUID <<FK, unique>>
        +bio : text?
        +gender : Gender
        +dateOfBirth : date
        +maritalStatus : MaritalStatus
        +religiousLevel : ReligiousLevel
        +ethnicity : varchar
        +nationality : varchar
        +height : float?
        +weight : float?
        +jobTitle : varchar?
        +education : EducationLevel
        +familyPlans : FamilyPlans
        +marriageIntention : MarriageIntention
        +interests : text[]
        +languages : text[]
        +aboutPartner : text?
        +latitude : float?
        +longitude : float?
        +city : varchar?
        +country : varchar?
        +showAge : boolean
        +showDistance : boolean
        +showOnlineStatus : boolean
        +showLastSeen : boolean
        +isComplete : boolean
        +profileCompletionPercentage : int
        +activityScore : int [0-100]
    }

    class Photo {
        +id : UUID <<PK>>
        +userId : UUID <<FK>>
        +url : varchar
        +publicId : varchar
        +isMain : boolean
        +isSelfieVerification : boolean
        +order : int
        +moderationStatus : PhotoModerationStatus
        +moderationNote : varchar?
        +createdAt : timestamp
    }

    class Like {
        +id : UUID <<PK>>
        +likerId : UUID <<FK>>
        +likedId : UUID <<FK>>
        +type : LikeType
        +isLike : boolean
        +complimentMessage : varchar?
        +createdAt : timestamp
        __
        <<unique>> (likerId, likedId)
    }

    class Match {
        +id : UUID <<PK>>
        +user1Id : UUID <<FK>>
        +user2Id : UUID <<FK>>
        +status : MatchStatus
        +matchedAt : timestamp
        +updatedAt : timestamp
        __
        <<unique>> (user1Id, user2Id)
    }

    class Conversation {
        +id : UUID <<PK>>
        +user1Id : UUID <<FK>>
        +user2Id : UUID <<FK>>
        +matchId : UUID <<FK>>
        +lastMessageContent : varchar?
        +lastMessageAt : timestamp?
        +lastMessageSenderId : UUID?
        +user1UnreadCount : int
        +user2UnreadCount : int
        +user1Muted : boolean
        +user2Muted : boolean
        +isActive : boolean
    }

    class Message {
        +id : UUID <<PK>>
        +conversationId : UUID <<FK>>
        +matchId : UUID <<FK>>
        +senderId : UUID <<FK>>
        +content : text
        +type : MessageType
        +status : MessageStatus
        +deliveredAt : timestamp?
        +readAt : timestamp?
        +createdAt : timestamp
    }

    class Notification {
        +id : UUID <<PK>>
        +userId : UUID <<FK>>
        +type : NotificationType
        +title : varchar
        +body : varchar
        +data : jsonb?
        +isRead : boolean
        +createdAt : timestamp
    }

    class Subscription {
        +id : UUID <<PK>>
        +userId : UUID <<FK>>
        +plan : SubscriptionPlan
        +status : SubscriptionStatus
        +startDate : timestamp?
        +endDate : timestamp?
        +paymentReference : varchar?
    }

    class Report {
        +id : UUID <<PK>>
        +reporterId : UUID <<FK>>
        +reportedId : UUID <<FK>>
        +reason : ReportReason
        +details : text?
        +status : ReportStatus
        +moderatorNote : text?
        +resolvedById : UUID?
    }

    class UserPreference {
        +id : UUID <<PK>>
        +userId : UUID <<FK, unique>>
        +minAge : int?
        +maxAge : int?
        +preferredGender : Gender?
        +maxDistance : int?
        +preferredEthnicities : text[]?
        +preferredNationalities : text[]?
        +preferredReligiousLevel : ReligiousLevel?
        +preferredMaritalStatus : MaritalStatus?
        +preferredInterests : text[]?
    }

    class BlockedUser {
        +id : UUID <<PK>>
        +blockerId : UUID <<FK>>
        +blockedId : UUID <<FK>>
        +createdAt : timestamp
    }

    class UserDevice {
        +id : UUID <<PK>>
        +userId : UUID <<FK>>
        +deviceFingerprint : varchar
        +deviceName : varchar?
        +platform : varchar?
        +osVersion : varchar?
        +appVersion : varchar?
        +ipAddress : varchar?
        +isTrusted : boolean
        +lastActiveAt : timestamp
        __
        <<unique>> (userId, deviceFingerprint)
    }

    class LoginHistory {
        +id : UUID <<PK>>
        +userId : UUID <<FK>>
        +ipAddress : varchar
        +userAgent : varchar?
        +deviceFingerprint : varchar?
        +country : varchar?
        +city : varchar?
        +result : LoginResult
        +failureReason : varchar?
        +isSuspicious : boolean
        +createdAt : timestamp
    }

    class UserBehavior {
        +id : UUID <<PK>>
        +userId : UUID <<FK, unique>>
        +preferredEthnicities : text[]
        +preferredReligiousLevels : text[]
        +preferredAgeMin : int?
        +preferredAgeMax : int?
        +preferredInterests : text[]
        +totalLikes : int
        +totalPasses : int
        +totalSuperLikes : int
        +totalMatches : int
        +totalMessagesStarted : int
        +likeToMatchRatio : float
        +daysActive : int
        +lastActiveDate : date?
    }

    class AnalyticsEvent {
        +id : UUID <<PK>>
        +eventType : AnalyticsEventType
        +userId : UUID?
        +metadata : jsonb?
        +eventDate : varchar
        +createdAt : timestamp
    }

    class ContentFlag {
        +id : UUID <<PK>>
        +userId : UUID <<FK>>
        +type : ContentFlagType
        +status : ContentFlagStatus
        +source : ContentFlagSource
        +content : text?
        +entityType : varchar
        +entityId : varchar
        +confidenceScore : float?
        +reviewedById : UUID?
        +reviewNote : text?
        +createdAt : timestamp
    }

    class EmailBlacklist {
        +id : UUID <<PK>>
        +domain : varchar <<unique>>
        +reason : varchar
        +isActive : boolean
        +addedBy : UUID
        +createdAt : timestamp
    }

    class Boost {
        +id : UUID <<PK>>
        +userId : UUID <<FK>>
        +type : BoostType
        +startedAt : timestamp
        +expiresAt : timestamp
        +profileViewsGained : int
        +isActive : boolean
        +createdAt : timestamp
    }
}

' ============================================================
' ENTITY RELATIONSHIPS
' ============================================================

User "1" -- "0..1" Profile : has >
User "1" -- "0..*" Photo : uploads >
User "1" -- "0..*" Like : sends >
User "1" -- "0..*" Match : participates >
User "1" -- "0..*" Conversation : participates >
User "1" -- "0..*" Message : sends >
User "1" -- "0..*" Notification : receives >
User "1" -- "0..*" Subscription : subscribes >
User "1" -- "0..*" Report : reports / reported >
User "1" -- "0..1" UserPreference : sets >
User "1" -- "0..*" BlockedUser : blocks >
User "1" -- "0..*" UserDevice : uses >
User "1" -- "0..*" LoginHistory : has >
User "1" -- "0..1" UserBehavior : tracked >
User "1" -- "0..*" AnalyticsEvent : generates >
User "1" -- "0..*" ContentFlag : flagged >
User "1" -- "0..*" Boost : activates >

Match "1" -- "0..1" Conversation : opens >
Conversation "1" -- "0..*" Message : contains >

Like "0..*" -- "1" User : liker >
Like "0..*" -- "1" User : liked >
Report "0..*" -- "1" User : reporter >
Report "0..*" -- "1" User : reported >
BlockedUser "0..*" -- "1" User : blocker >
BlockedUser "0..*" -- "1" User : blocked >

