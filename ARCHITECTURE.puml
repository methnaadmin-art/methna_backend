' ============================================================
' REDIS CACHE DETAIL
' ============================================================

package "Redis Cache Keys" <<Database>> #FFEBEE {
    note as RedisKeys
        **User & Profile Cache**
        user:{id} → 5min
        profile:{id} → 5min

        **Suggestions & Search**
        suggestions:{id} → 10min
        smart_suggestions:{id} → 5min
        search:{id}:{hash} → 5min

        **Compatibility**
        compat:{id} → 1h

        **Monetization**
        plan:{id} → 1h
        features:{id} → 1h
        boost:{id} → dynamic TTL
        likes_used:{id}:{date} → 24h

        **Trust & Safety**
        shadowban:{id} → 1h
        email_bl:{domain} → 24h

        **Presence**
        online_users (SET)
        lastSeen:{id} → 30d

        **Rate Limiting**
        otp:{id} → 30s
        otp_cooldown:{email} → 60s
        login_attempts:{email} → 1h
        ip_limit:{ip}:{endpoint} → dynamic
        ratelimit:{key} → dynamic

        **Analytics**
        analytics:{type}:{date} → 90d
        analytics:dau:{date} → 1h
        analytics:admin:{date} → 30min
        analytics:retention:{days} → 1h
    end note
}

' ============================================================
' WEBSOCKET MESSAGE FLOW
' ============================================================

package "WebSocket Flow (Socket.IO /chat)" <<Cloud>> #E0F7FA {
    note as WSFlow
        **Client → Server Events**
        ─ joinConversation({conversationId})
        ─ leaveConversation({conversationId})
        ─ sendMessage({conversationId, content, type?, imageUrl?})
        ─ typing({conversationId})
        ─ stopTyping({conversationId})
        ─ markRead({conversationId})
        ─ markDelivered({conversationId})
        ─ checkOnline({userId})

        **Server → Client Events**
        ─ userOnline({userId, timestamp})
        ─ userOffline({userId, lastSeen})
        ─ newMessage({id, conversationId, senderId, ...})
        ─ userTyping / userStoppedTyping
        ─ messagesRead / messagesDelivered

        **Flow:**
        Client connects → Redis setUserOnline
        Client sends msg → TrustSafety filter → DB save → emit newMessage
        Client disconnects → Redis setUserOffline → store lastSeen
    end note
}

