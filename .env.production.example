# Production runtime profile (example)
# Copy to your deployment secrets manager, do NOT commit real values.

NODE_ENV=production
PORT=3000
API_PREFIX=api/v1
CORS_ORIGIN=https://app.methna.com

# JWT (must be strong, unique values)
JWT_SECRET=replace-with-strong-random-secret
JWT_EXPIRATION=15m
JWT_REFRESH_SECRET=replace-with-strong-random-refresh-secret
JWT_REFRESH_EXPIRATION=7d

# Database
DB_HOST=your-production-db-host
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=replace-with-db-password
DB_NAME=postgres
DB_SSL=true

# Redis
REDIS_URL=rediss://your-production-redis-endpoint
REDIS_TOKEN=replace-with-redis-token

# Google Play Billing (required in production)
GOOGLE_PLAY_ALLOW_UNVERIFIED_TOKENS=false
GOOGLE_PLAY_CLIENT_EMAIL=service-account@project-id.iam.gserviceaccount.com
GOOGLE_PLAY_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nREPLACE_WITH_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"
GOOGLE_PLAY_PACKAGE_NAME=com.methnapp.app
GOOGLE_PLAY_LICENSING_PUBLIC_KEY=replace-with-licensing-public-key
GOOGLE_PLAY_SUBSCRIPTION_MANAGEMENT_URL=https://play.google.com/store/account/subscriptions
GOOGLE_PLAY_UCB_ELIGIBLE_COUNTRIES=GB

# Firebase
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_CLIENT_EMAIL=firebase-admin@project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nREPLACE_WITH_FIREBASE_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"

# Mail / integrations (fill as needed)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=replace-with-mail-user
MAIL_PASS=replace-with-mail-password
MAIL_FROM=no-reply@your-domain.com
RESEND_API_KEY=replace-with-resend-key
